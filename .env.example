# ─────────────────────────────────────────
# Server
# ─────────────────────────────────────────
PORT=3000

# ─────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────
SUPABASE_URL=
SUPABASE_KEY=

# ─────────────────────────────────────────
# Gemini
# ─────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_MODEL_PRO=gemini-3.1-pro-preview

# ─────────────────────────────────────────
# Grok (optional — X 카테고리 심층 분석)
# ─────────────────────────────────────────
GROK_API_KEY=
GROK_MODEL=grok-3-fast

# ─────────────────────────────────────────
# Scraper — Reddit
# ─────────────────────────────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ─────────────────────────────────────────
# Scraper — Google Custom Search
# ─────────────────────────────────────────
GOOGLE_SEARCH_CX=
GOOGLE_SEARCH_API_KEY=

# ─────────────────────────────────────────
# Scraper — StackOverflow
# ─────────────────────────────────────────
STACKOVERFLOW_KEY=

# ─────────────────────────────────────────
# Email — Resend (뉴스레터 발송)
# ─────────────────────────────────────────
RESEND_API_KEY=
TEST_EMAIL_RECIPIENT=

# ─────────────────────────────────────────
# Pipeline API (수동 실행 인증키)
# ─────────────────────────────────────────
PIPELINE_API_KEY=

# ─────────────────────────────────────────
# CORS — 허용 origin (콤마 구분)
# ─────────────────────────────────────────
FRONTEND_URL=https://trendiv.org,https://trendiv-web.pages.dev,https://develop.trendiv-web.pages.dev,http://localhost:5173

# ─────────────────────────────────────────
# Batch Mode (GitHub Actions 전용)
# ─────────────────────────────────────────
# BATCH_MODE=true
# BATCH_TYPE=pipeline   # pipeline | retry
